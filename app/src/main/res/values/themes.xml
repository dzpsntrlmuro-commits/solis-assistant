<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.HelloKittiy" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/pink_500</item>
        <item name="colorPrimaryVariant">@color/pink_700</item>
        <item name="colorSecondary">@color/pink_300</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/pink_200</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@drawable/bg_home_wallpaper</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Theme.HelloKittiy.Launcher" parent="Theme.HelloKittiy">
        <item name="android:windowShowWallpaper">false</item>
        <item name="android:windowFullscreen">false</item>
    </style>

    <style name="KittiyText.Brand" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textColor">@color/pink_700</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="KittiyText.PanelTitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
