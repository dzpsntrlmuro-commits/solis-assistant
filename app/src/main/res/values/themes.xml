<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Murotube" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryDark">@color/accent_dark</item>
        <item name="colorSecondary">@color/teal</item>
        <item name="colorOnPrimary">@color/on_accent</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:colorBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/teal</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@drawable/bg_app</item>
        <item name="android:fontFamily">@font/outfit</item>
        <item name="fontFamily">@font/outfit</item>
    </style>

    <style name="Theme.Murotube.Player" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:statusBarColor">@color/player_bg</item>
        <item name="android:navigationBarColor">@color/player_bg</item>
        <item name="android:windowBackground">@color/player_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:fontFamily">@font/outfit</item>
    </style>

    <style name="Text.Murotube.Brand" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">@font/outfit_bold</item>
        <item name="android:textColor">@color/surface</item>
        <item name="android:textSize">42sp</item>
        <item name="android:letterSpacing">-0.03</item>
    </style>

    <style name="Text.Murotube.BrandCompact" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/outfit_bold</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textSize">22sp</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>
</resources>
