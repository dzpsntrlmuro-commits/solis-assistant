<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.HelloKittiy" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/pink_main</item>
        <item name="colorPrimaryVariant">@color/pink_deep</item>
        <item name="colorSecondary">@color/bow_red</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@color/pink_main</item>
        <item name="android:navigationBarColor">@color/pink_soft</item>
        <item name="android:windowBackground">@color/pink_pale</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Theme.HelloKittiy.Launcher" parent="Theme.HelloKittiy">
        <item name="android:windowShowWallpaper">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>
</resources>
