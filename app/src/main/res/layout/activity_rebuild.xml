<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_hero"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:navigationIconTint="@color/ink"
        app:title="Yeniden paketle"
        app:titleTextColor="@color/ink" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            style="@style/Text.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Çıkarılmış klasörden imzasız bir APK üretir. Kurulum için kendi anahtarınızla imzalamanız gerekir. Yalnızca kendi uygulamanız için kullanın."
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRebuild"
            style="@style/Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/rebuild" />

        <TextView
            android:id="@+id/report"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_panel"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.3"
            android:padding="14dp"
            android:textColor="@color/ink"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
