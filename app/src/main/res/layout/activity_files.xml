<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_hero"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:navigationIconTint="@color/ink"
        app:title="Dosya gezgini"
        app:titleTextColor="@color/ink" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExtracted"
                style="@style/Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="Çıkarılan" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWorkspace"
                style="@style/Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="Atölye" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickFolder"
                style="@style/Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="Klasör aç" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUp"
                style="@style/Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Üst klasör" />
        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/pathLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:ellipsize="start"
        android:singleLine="true"
        android:textColor="@color/muted"
        android:textSize="12sp"
        android:fontFamily="monospace" />

    <EditText
        android:id="@+id/search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_panel"
        android:hint="Dosya ara…"
        android:inputType="text"
        android:padding="12dp"
        android:textColor="@color/ink"
        android:textColorHint="@color/muted"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/emptyHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="@drawable/bg_panel"
        android:padding="14dp"
        android:text="Henüz çıkarılmış dosya yok. Ana ekrandan APK seçip «İçeriği çıkar» deyin veya «Klasör aç» ile kendi dosyalarınıza gidin."
        android:textColor="@color/muted"
        android:textSize="13sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="12dp" />
</LinearLayout>
