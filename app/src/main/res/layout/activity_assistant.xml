<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_hero"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:navigationIconTint="@color/ink"
        app:title="Asistan"
        app:titleTextColor="@color/ink" />

    <LinearLayout
        android:id="@+id/briefPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:background="@drawable/bg_status"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ARKA PLAN ODAK"
            android:textColor="@color/amber_soft"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <TextView
            android:id="@+id/briefText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Seni dinliyorum — söylediklerin burada toplanacak."
            android:textColor="@color/white"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.25" />
    </LinearLayout>

    <TextView
        android:id="@+id/hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:text="Serbest konuş. Her cümlen not alınır; «Uygula» ile hepsini işlerim."
        android:textColor="@color/muted"
        android:textSize="13sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@drawable/bg_panel"
        android:layout_margin="12dp">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipListen"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sürekli dinle"
                    android:textAllCaps="false"
                    android:textColor="@color/teal" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipApply"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Uygula"
                    android:textAllCaps="false"
                    android:textColor="@color/amber" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipBrief"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Özet"
                    android:textAllCaps="false"
                    android:textColor="@color/teal" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipApi"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="API"
                    android:textAllCaps="false"
                    android:textColor="@color/amber" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipPickImage"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Görsel"
                    android:textAllCaps="false"
                    android:textColor="@color/teal" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipRebuild"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Paketle"
                    android:textAllCaps="false"
                    android:textColor="@color/teal" />
            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Doğal konuş — her şeyini dinliyorum…"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="5"
                android:padding="8dp"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted"
                android:textSize="15sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMic"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:text="Ses"
                android:textAllCaps="false"
                android:textColor="@color/teal" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSend"
                style="@style/Button.Primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:paddingHorizontal="16dp"
                android:text="Gönder" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
