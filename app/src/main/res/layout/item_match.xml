<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_match_row"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/txtLeague"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/muted_text"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingLeft="10dp"
            android:paddingTop="4dp"
            android:paddingRight="10dp"
            android:paddingBottom="4dp"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtTeams"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/cream_text"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtScore"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/accent_amber"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Seçim kutuları üstte: hemen görünsün -->
    <TextView
        android:id="@+id/txtPickTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="1 / X / 2 seç"
        android:textColor="@color/accent_amber"
        android:textSize="13sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/pickRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnPickHome"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_pick_idle"
            android:gravity="center"
            android:text="1\nEv"
            android:textColor="@color/cream_text"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnPickDraw"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_pick_idle"
            android:gravity="center"
            android:text="X\nBer."
            android:textColor="@color/cream_text"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnPickAway"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_weight="1"
            android:background="@drawable/bg_pick_idle"
            android:gravity="center"
            android:text="2\nDep"
            android:textColor="@color/cream_text"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtPickState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/accent_amber"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtWeather"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/muted_text"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/txtWinLine"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/cream_text"
        android:textSize="12sp" />

    <ProgressBar
        android:id="@+id/barHome"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="6dp"
        android:max="100"
        android:progressDrawable="@drawable/progress_home" />

    <ProgressBar
        android:id="@+id/barDraw"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="3dp"
        android:max="100"
        android:progressDrawable="@drawable/progress_draw" />

    <ProgressBar
        android:id="@+id/barAway"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="3dp"
        android:max="100"
        android:progressDrawable="@drawable/progress_away" />

    <TextView
        android:id="@+id/txtSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="@color/muted_text"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/btnOpenDetail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:paddingTop="4dp"
        android:paddingBottom="2dp"
        android:text="Detay / analiz ›"
        android:textColor="@color/pitch_light"
        android:textSize="12sp" />
</LinearLayout>
