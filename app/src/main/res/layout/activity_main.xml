<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app">

    <!-- Compact top bar (after search) -->
    <LinearLayout
        android:id="@+id/compactHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:contentDescription="@string/app_name"
                android:src="@drawable/logo_murotube" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/outfit_bold"
                    android:text="@string/app_name"
                    android:textColor="@color/ink"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/outfit_medium"
                    android:text="@string/brand_sub"
                    android:textColor="@color/teal_mid"
                    android:textSize="11sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/downloadsButton"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/downloads_title"
                android:padding="9dp"
                android:src="@drawable/ic_download"
                app:tint="@color/ink" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_search_bar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="6dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_search" />

            <EditText
                android:id="@+id/searchInput"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:fontFamily="@font/outfit_regular"
                android:hint="@string/search_hint"
                android:imeOptions="actionSearch"
                android:importantForAutofill="no"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted"
                android:textSize="15sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/searchButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:paddingHorizontal="14dp"
                android:text="@string/search"
                android:textAllCaps="false"
                android:fontFamily="@font/outfit_medium"
                app:backgroundTint="@color/accent"
                app:cornerRadius="14dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_search_bar_alt"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="6dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_search" />

            <EditText
                android:id="@+id/filmSearchInput"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:fontFamily="@font/outfit_regular"
                android:hint="@string/film_search_hint"
                android:imeOptions="actionSearch"
                android:importantForAutofill="no"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/ink"
                android:textColorHint="@color/muted"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/filmSearchButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:fontFamily="@font/outfit_medium"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:paddingHorizontal="12dp"
                android:text="@string/search"
                android:textAllCaps="false"
                app:backgroundTint="@color/teal"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Landing hero (first open / empty) -->
    <FrameLayout
        android:id="@+id/landingHero"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_hero"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible">

        <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="-40dp"
            android:layout_marginEnd="-50dp"
            android:alpha="0.18"
            android:background="@drawable/bg_orb" />

        <View
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="-40dp"
            android:layout_marginBottom="80dp"
            android:alpha="0.14"
            android:background="@drawable/bg_orb_accent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="72dp"
            android:paddingBottom="36dp">

            <ImageView
                android:id="@+id/heroLogo"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:contentDescription="@string/app_name"
                android:elevation="6dp"
                android:src="@drawable/logo_murotube" />

            <TextView
                android:id="@+id/brandTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="@font/outfit_bold"
                android:letterSpacing="-0.03"
                android:text="@string/app_name"
                android:textColor="@color/surface"
                android:textSize="44sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/outfit_medium"
                android:letterSpacing="0.12"
                android:text="@string/brand_sub"
                android:textAllCaps="true"
                android:textColor="#B7E0E6"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="@font/outfit_regular"
                android:gravity="center"
                android:text="@string/tagline"
                android:textColor="#D5EBEE"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="36dp"
                android:background="@drawable/bg_search_bar"
                android:elevation="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="6dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_search" />

                <EditText
                    android:id="@+id/landingSearchInput"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/outfit_regular"
                    android:hint="@string/search_hint"
                    android:imeOptions="actionSearch"
                    android:importantForAutofill="no"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textColor="@color/ink"
                    android:textColorHint="@color/muted"
                    android:textSize="16sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/landingSearchButton"
                    android:layout_width="wrap_content"
                    android:layout_height="46dp"
                    android:fontFamily="@font/outfit_medium"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:paddingHorizontal="18dp"
                    android:text="@string/search"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/accent"
                    app:cornerRadius="16dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_search_bar_alt"
                android:elevation="3dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="6dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_search" />

                <EditText
                    android:id="@+id/landingFilmSearchInput"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/outfit_regular"
                    android:hint="@string/film_search_hint"
                    android:imeOptions="actionSearch"
                    android:importantForAutofill="no"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textColor="@color/ink"
                    android:textColorHint="@color/muted"
                    android:textSize="16sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/landingFilmSearchButton"
                    android:layout_width="wrap_content"
                    android:layout_height="46dp"
                    android:fontFamily="@font/outfit_medium"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:paddingHorizontal="18dp"
                    android:text="@string/search"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/teal"
                    app:cornerRadius="16dp" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/trendingButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/outfit_medium"
                android:text="@string/trending"
                android:textAllCaps="false"
                android:textColor="@color/surface"
                app:cornerRadius="16dp"
                app:strokeColor="#66FFFFFF"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/landingDownloadsButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/outfit_medium"
                android:text="@string/downloads_title"
                android:textAllCaps="false"
                android:textColor="@color/surface"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_download"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="@color/surface"
                app:strokeColor="#66FFFFFF"
                app:strokeWidth="1dp" />
        </LinearLayout>
    </FrameLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/compactHeader">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bg">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/resultsList"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="24dp"
                tools:listitem="@layout/item_video" />

            <ProgressBar
                android:id="@+id/loading"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/accent"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/errorState"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/errorText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/outfit_regular"
                    android:gravity="center"
                    android:textColor="@color/ink"
                    android:textSize="16sp"
                    tools:text="Hata" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/retryButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/outfit_medium"
                    android:text="@string/retry"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/accent"
                    app:cornerRadius="14dp" />
            </LinearLayout>
        </FrameLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
