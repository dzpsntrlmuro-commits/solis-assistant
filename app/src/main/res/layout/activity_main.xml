<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_atmosphere">

    <View
        android:id="@+id/heroGlow"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_hero_glow"
        android:alpha="0.85" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="72dp"
        android:paddingBottom="40dp">

        <TextView
            android:id="@+id/brandTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/cormorant_garamond_semibold"
            android:letterSpacing="0.08"
            android:text="@string/brand_name"
            android:textColor="@color/gold_bright"
            android:textSize="56sp" />

        <TextView
            android:id="@+id/tagline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/manrope_regular"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="@string/tagline"
            android:textColor="@color/cream"
            android:textSize="17sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_cta"
            android:fontFamily="@font/manrope_regular"
            android:gravity="center"
            android:text="@string/cta_start"
            android:textColor="@color/ink"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/manrope_regular"
            android:gravity="center"
            android:text="@string/disclaimer"
            android:textColor="@color/muted"
            android:textSize="11sp" />
    </LinearLayout>
</FrameLayout>
