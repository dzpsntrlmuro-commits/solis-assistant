<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_wallpaper"
    android:fitsSystemWindows="true">

    <!-- HOME SCREEN -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/homeLayer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp">

        <View
            android:id="@+id/pullHintBar"
            android:layout_width="48dp"
            android:layout_height="5dp"
            android:background="@drawable/bg_panel_handle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvClock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.04"
            android:text="12:00"
            android:textColor="@color/pink_700"
            android:textSize="64sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/pullHintBar" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_muted"
            android:textSize="15sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvClock" />

        <ImageView
            android:id="@+id/imgKitty"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_marginTop="12dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_kitty_face"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvDate" />

        <TextView
            android:id="@+id/tvBrand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/app_name"
            android:textAppearance="@style/KittiyText.Brand"
            android:textSize="30sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imgKitty" />

        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_subtitle"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvBrand" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_dock"
            android:drawableStart="@drawable/ic_kitty_small"
            android:drawablePadding="10dp"
            android:hint="@string/search_hint"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:paddingHorizontal="14dp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/text_muted"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvGreeting" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvApps"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingBottom="8dp"
            app:layout_constraintBottom_toTopOf="@id/dock"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/etSearch" />

        <LinearLayout
            android:id="@+id/dock"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_dock"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageButton
                android:id="@+id/btnDockPhone"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/dock_phone"
                android:src="@drawable/ic_dock_phone" />

            <ImageButton
                android:id="@+id/btnDockMessages"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/dock_messages"
                android:src="@drawable/ic_dock_messages" />

            <ImageButton
                android:id="@+id/btnDockCamera"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/dock_camera"
                android:src="@drawable/ic_dock_camera" />

            <ImageButton
                android:id="@+id/btnDockSettings"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/dock_settings"
                android:src="@drawable/ic_dock_settings" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- SCRIM -->
    <View
        android:id="@+id/scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/scrim"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

    <!-- PINK HELLO KITTY NOTIFICATION + SOUND PANEL -->
    <LinearLayout
        android:id="@+id/notificationPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@drawable/bg_notification_panel"
        android:clickable="true"
        android:elevation="16dp"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="20dp"
        android:translationY="-1200dp"
        android:visibility="visible">

        <View
            android:layout_width="44dp"
            android:layout_height="5dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_panel_handle" />

        <!-- Hello Kitty header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_kitty_face" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/notifications_title"
                    android:textColor="#F2FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>

            <ImageView
                android:layout_width="28dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_bow" />
        </LinearLayout>

        <!-- TOP PANEL KITTY TILES: wifi / mute / home -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/tileWifi"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_quick_tile"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/quick_wifi"
                    android:src="@drawable/ic_tile_wifi_kitty" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="14dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="6dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_bow" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/tileSilent"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_quick_tile"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/quick_silent"
                    android:src="@drawable/ic_tile_mute_kitty" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="14dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="6dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_bow" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/tileLauncher"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:background="@drawable/bg_quick_tile"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/set_default_launcher"
                    android:src="@drawable/ic_tile_home_kitty" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="14dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="6dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_bow" />
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="@string/notifications_title"
                android:src="@drawable/ic_notif_kitty" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/notifications_title"
                android:textAppearance="@style/KittiyText.PanelTitle"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/btnClearNotifs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:padding="8dp"
                android:text="@string/clear_all"
                android:textColor="@color/white"
                android:textSize="13sp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvNotifications"
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:layout_marginTop="8dp"
            android:overScrollMode="never" />

        <TextView
            android:id="@+id/tvEmptyNotifs"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:gravity="center"
            android:text="@string/no_notifications"
            android:textColor="#EEFFFFFF"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- SOUND + MUTE SECTION (Hello Kitty) -->
        <FrameLayout
            android:id="@+id/soundSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_sound_card"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:contentDescription="@string/sound_title"
                        android:src="@drawable/ic_sound_kitty" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="@string/sound_title"
                        android:textAppearance="@style/KittiyText.PanelTitle"
                        android:textSize="16sp" />

                    <ImageView
                        android:id="@+id/btnMuteKitty"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/quick_silent"
                        android:padding="2dp"
                        android:src="@drawable/ic_tile_mute_kitty" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/volume_media"
                    android:textColor="#F5FFFFFF"
                    android:textSize="12sp" />

                <SeekBar
                    android:id="@+id/seekMedia"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="@color/white"
                    android:thumbTint="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/volume_ring"
                    android:textColor="#F5FFFFFF"
                    android:textSize="12sp" />

                <SeekBar
                    android:id="@+id/seekRing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="@color/white"
                    android:thumbTint="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/volume_alarm"
                    android:textColor="#F5FFFFFF"
                    android:textSize="12sp" />

                <SeekBar
                    android:id="@+id/seekAlarm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="@color/white"
                    android:thumbTint="@color/white" />
            </LinearLayout>

            <ImageView
                android:layout_width="24dp"
                android:layout_height="18dp"
                android:layout_gravity="top|end"
                android:layout_marginEnd="8dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_bow" />
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
