<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_gradient">

    <!-- Decorative soft blobs -->
    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-40dp"
        android:layout_marginEnd="-50dp"
        android:alpha="0.35"
        android:background="@drawable/bg_icon_circle" />

    <View
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="120dp"
        android:layout_marginStart="-40dp"
        android:alpha="0.25"
        android:background="@drawable/bg_icon_circle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="12dp">

        <!-- Status / brand bar -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="18dp"
            android:paddingVertical="8dp">

            <ImageView
                android:id="@+id/imgBrand"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_kittiy_face" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvBrand"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.02"
                    android:text="@string/app_name"
                    android:textColor="@color/ink"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvClock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/ink_soft"
                    android:textSize="13sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnOpenPanel"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_fab"
                android:contentDescription="@string/panel_notifications"
                android:padding="10dp"
                android:src="@drawable/ic_bell" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:text="@string/home_hint"
            android:textColor="@color/ink_soft"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="18dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_search"
            android:hint="@string/search_hint"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:paddingHorizontal="18dp"
            android:textColor="@color/ink"
            android:textColorHint="@color/ink_soft"
            android:textSize="14sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvApps"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingHorizontal="12dp"
            android:paddingBottom="8dp" />

        <!-- Dock -->
        <LinearLayout
            android:id="@+id/dock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_dock"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="14dp">

            <ImageButton
                android:id="@+id/dockPhone"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/bg_icon_circle"
                android:contentDescription="Telefon"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_menu_call" />

            <ImageButton
                android:id="@+id/dockSms"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/bg_icon_circle"
                android:contentDescription="Mesaj"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_dialog_email" />

            <ImageButton
                android:id="@+id/dockCamera"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/bg_icon_circle"
                android:contentDescription="Kamera"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_menu_camera" />

            <ImageButton
                android:id="@+id/dockSettings"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/bg_icon_circle"
                android:contentDescription="Ayarlar"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_menu_preferences" />
        </LinearLayout>
    </LinearLayout>

    <!-- Scrim -->
    <View
        android:id="@+id/scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/scrim"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

    <!-- Pink notification + sound panel -->
    <include
        android:id="@+id/quickPanel"
        layout="@layout/panel_quick"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:visibility="gone" />

</FrameLayout>
