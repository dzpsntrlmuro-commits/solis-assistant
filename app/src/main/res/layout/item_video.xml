<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/ink_800"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/card_stroke"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp">

        <ImageView
            android:id="@+id/ivThumb"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_thumb"
            android:contentDescription="@string/app_name"
            android:scaleType="centerCrop"
            app:layout_constraintDimensionRatio="16:9"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:background="@drawable/bg_duration"
            android:fontFamily="@font/outfit_medium"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:textColor="@color/mist_100"
            android:textSize="11sp"
            app:layout_constraintBottom_toBottomOf="@id/ivThumb"
            app:layout_constraintEnd_toEndOf="@id/ivThumb"
            tools:text="12:34" />

        <TextView
            android:id="@+id/badgeBlocked"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:background="@drawable/bg_badge"
            android:fontFamily="@font/outfit_semibold"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="@string/ad_blocked_badge"
            android:textColor="@color/teal_400"
            android:textSize="10sp"
            app:layout_constraintStart_toStartOf="@id/ivThumb"
            app:layout_constraintTop_toTopOf="@id/ivThumb" />

        <TextView
            android:id="@+id/tvTitle"
            style="@style/Text.Title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:ellipsize="end"
            android:maxLines="2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivThumb"
            tools:text="Video başlığı burada görünür" />

        <TextView
            android:id="@+id/tvMeta"
            style="@style/Text.Meta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            tools:text="Kanal • 1.2M izlenme" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
